# Public URL of the FastAPI backend (Google Cloud Run).
#
# Read in two places:
#   - pages/api/*.js  — the WEB build's server-side proxy routes forward here.
#   - lib/api.js      — the NATIVE (Capacitor) build calls it directly, since the
#                       static export has no Node server to run the proxy routes.
#
# NEXT_PUBLIC_ is inlined into the client bundle at build time, so this value is
# public by design (no secret) — committing it keeps native builds reproducible.
# Override locally with .env.local (gitignored) when pointing at a dev backend.
NEXT_PUBLIC_BACKEND_URL=https://bgita-api-779962872048.us-central1.run.app
